# Скопируйте в .env и заполните

# OpenRouter API Key (обязательно)
# Получить: https://openrouter.ai/keys
COD_DOC_API_KEY=sk-or-v1-...

# Модель LLM (OpenRouter model ID)
COD_DOC_MODEL=anthropic/claude-sonnet-4-6

# URL API (для OpenRouter оставьте как есть)
COD_DOC_BASE_URL=https://openrouter.ai/api/v1

# Авто-коммит изменений в git после выполнения задачи
COD_DOC_AUTO_COMMIT=false

# Интервал опроса задач в daemon-режиме (секунды)
COD_DOC_AGENT_INTERVAL=60

# Макс. итераций агента за одну задачу
COD_DOC_MAX_ITERATIONS=50

# REST API
COD_DOC_API_PORT=8765

# Логирование (json для Docker, text для разработки)
LOG_FORMAT=text
LOG_LEVEL=INFO
