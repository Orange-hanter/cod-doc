#!/usr/bin/env bash
# COD-DOC pre-commit hook
# Проверяет:
#   1. Формат гибридных ссылок в .md файлах
#   2. Наличие self_check JSON в изменённых файлах (если требуется)
#   3. Что MASTER.md не содержит явно сломанных ссылок (🔴 BROKEN/STALE)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
ERRORS=0

# ── Цвета ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'

echo "🔍 COD-DOC pre-commit check..."

# ── 1. Получить список изменённых .md файлов ────────────────────────────────
CHANGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [[ -z "$CHANGED_MD" ]]; then
  echo -e "${GREEN}✅ Нет изменённых .md файлов — проверка пропущена.${NC}"
  exit 0
fi

# ── 2. Проверка формата гибридных ссылок ────────────────────────────────────
# Ссылка должна соответствовать: 📁 /path | 🗃️ doc:id | 🔑 sha:12hex
LINK_REGEX='📁[[:space:]]+[^|]+\|[[:space:]]+🗃️[[:space:]]+[^|]+\|[[:space:]]+🔑[[:space:]]+sha:[0-9a-f]{12}'

while IFS= read -r file; do
  # Ищем строки с эмодзи 📁 — они должны соответствовать шаблону
  LINK_LINES=$(git show ":$file" | grep -n '📁' || true)
  if [[ -n "$LINK_LINES" ]]; then
    MALFORMED=$(echo "$LINK_LINES" | grep -vP "$LINK_REGEX" || true)
    if [[ -n "$MALFORMED" ]]; then
      echo -e "${RED}❌ MALFORMED LINKS в $file:${NC}"
      echo "$MALFORMED"
      ERRORS=$((ERRORS + 1))
    fi
  fi
done <<< "$CHANGED_MD"

# ── 3. Проверка MASTER.md на 🔴 STALE / 🔴 BROKEN ─────────────────────────
if echo "$CHANGED_MD" | grep -q 'MASTER\.md'; then
  STALE=$(git show ":MASTER.md" | grep -n '🔴' || true)
  if [[ -n "$STALE" ]]; then
    echo -e "${YELLOW}⚠️  MASTER.md содержит устаревшие/сломанные ссылки:${NC}"
    echo "$STALE"
    echo -e "${YELLOW}   Запустите: python tools/hash_calc.py update MASTER.md${NC}"
    ERRORS=$((ERRORS + 1))
  fi
fi

# ── 4. Итог ────────────────────────────────────────────────────────────────
if [[ $ERRORS -gt 0 ]]; then
  echo -e "${RED}❌ pre-commit: обнаружено $ERRORS ошибок. Коммит отклонён.${NC}"
  exit 1
fi

echo -e "${GREEN}✅ pre-commit: все проверки пройдены.${NC}"
exit 0
